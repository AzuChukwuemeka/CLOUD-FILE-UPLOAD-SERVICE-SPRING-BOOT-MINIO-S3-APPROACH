# Copy this file to .env (or export these as real environment variables) and adjust as needed.
# The application reads these via application.yaml; sensible local defaults are already baked in,
# so this file is only needed if you want to point at a different MinIO instance/bucket.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=file-uploader-bucket
